{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": [
    {
      "key": "NEXT_PUBLIC_SITE_URL",
      "description": "The production URL of the website",
      "value": "https://nelsonislamicsociety.org.nz"
    },
    {
      "key": "CONTACT_EMAIL",
      "description": "Email address to receive contact form submissions",
      "value": "contact@nelsonislamicsociety.org.nz"
    },
    {
      "key": "RESEND_API_KEY",
      "description": "API key for Resend email service (optional if using SendGrid)",
      "value": ""
    },
    {
      "key": "SENDGRID_API_KEY",
      "description": "API key for SendGrid email service (optional if using Resend)",
      "value": ""
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
